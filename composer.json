{
    "name": "globalis/wp-cubi-castor",
    "description": "Castor task runner OOP pour projets WordPress Bedrock/Cubi — remplace wp-cubi-robo + wp-cubi-robo-globalis",
    "type": "library",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": ">=8.1",
        "jolicode/castor": "^0.21",
        "scssphp/scssphp": "^1.12",
        "tedivm/jshrink": "^1.4",
        "padaliyajay/php-autoprefixer": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "WpCubiCastor\\": "src/"
        },
        "exclude-from-classmap": [
            "src/tasks/",
            "src/bootstrap.php"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
